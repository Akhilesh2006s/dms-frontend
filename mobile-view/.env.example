# API Backend Configuration
# Copy to .env and adjust as needed

# Option 1: Use production backend (works everywhere - phone, web, any network)
EXPO_PUBLIC_USE_PRODUCTION=true

# Option 2: Use local backend - set EXPO_PUBLIC_API_URL
# For web (browser): http://localhost:5000/api
# For device:        http://YOUR_COMPUTER_IP:5000/api  (run ipconfig / ifconfig to find IP)

# EXPO_PUBLIC_API_URL=http://localhost:5000/api
